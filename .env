# Organization & User IDs (from your CourtReserve account)
ORG_ID=7031
USER_ID=5384796
MEMBERSHIP_ID=2346339

# Event Configuration
# Per-location event type IDs and preferred days
# Format: eventTypeId:day1,day2;eventTypeId:day3,day4
# Renton Organized Play = 19756
# Redmond Organized Play = 54834
# EVENT_CONFIGS=19756:tuesday,thursday;54834:monday,wednesday,friday
EVENT_CONFIGS=54834:monday,wednesday,friday

# Polling interval in minutes
CHECK_INTERVAL_MINUTES=3

# Run in headless mode (true = no browser window, false = show browser)
HEADLESS=true

# Desktop notification on macOS (true/false)
ENABLE_NOTIFICATIONS=true

# Max weeks ahead to book (skip dates further out)
MAX_WEEKS_AHEAD=4

# ─── Email Notifications ─────────────────────────────────────────
# For Gmail: use an App Password (not your regular password)
# Go to: https://myaccount.google.com/apppasswords
# Create one for "Mail" → "Other (Custom name)" → "Mixer Bot"
NOTIFY_EMAIL_USER=sahilverma.0922@gmail.com
NOTIFY_EMAIL_PASS=xxxx xxxx xxxx xxxx
NOTIFY_EMAIL_TO=sahilverma.0922@gmail.com
